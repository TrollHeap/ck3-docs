---
const { items = [] } = Astro.props;
---

<div class="checklistBackdrop" data-checklist-backdrop aria-hidden="true"></div>

<button class="checklistFab" type="button" data-checklist-open
        aria-label="Open debug checklist" aria-expanded="false" aria-controls="checklistDrawer">
  Checklist
  <span class="checklistBadge" data-checklist-count aria-live="polite"></span>
</button>

<aside class="checklistDrawer" id="checklistDrawer" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Debug checklist">
  <div class="drawerHeader">
    <h3>Checklist</h3>
    <button class="drawerClose" type="button" data-checklist-close aria-label="Close">×</button>
  </div>
  <div>
    {items.map((item, index) => (
      <label class="check">
        <input type="checkbox" data-check-item={index} />
        <span>{item}</span>
      </label>
    ))}
  </div>
</aside>
