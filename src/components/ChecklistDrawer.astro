---
const { items = [] } = Astro.props;
---

<button class="checklistFab" type="button" data-checklist-open aria-label="Open debug checklist" aria-expanded="false" aria-controls="checklistDrawer">☑ Checklist</button>

<aside class="checklistDrawer" id="checklistDrawer" aria-hidden="true" aria-label="Debug checklist">
  <div class="drawerHeader">
    <h3>Checklist</h3>
    <button class="themeToggle" type="button" data-checklist-close aria-label="Close checklist">×</button>
  </div>
  <div>
    {items.map((item, index) => (
      <label class="check">
        <input type="checkbox" data-check-item={index} />
        <span>{item}</span>
      </label>
    ))}
  </div>
</aside>
