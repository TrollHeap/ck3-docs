---
import '../styles/global.css';
import data from '../data/appData.json';
import ChecklistDrawer from '../components/ChecklistDrawer.astro';
import { langPath, langs } from '../utils/paths.js';
import { ClientRouter } from 'astro:transitions';

const {
  lang = 'en',
  active = 'docs',
  title = 'CK3 Scenario Docs',
  sidebarItems = [],
  currentId = '',
  recipeId = ''
} = Astro.props;

const L = data.i18n[lang] || data.i18n.en;
const hasSidebar = sidebarItems.length > 0 && active !== 'recipes';

const firstRecipeId = L.recipes?.[0]?.id || '';

function recipeHome(targetLang = lang) {
  const targetL = data.i18n[targetLang] || data.i18n.en;
  const targetFirst = targetL.recipes?.[0]?.id || firstRecipeId;
  return langPath(targetLang, 'recipes', targetFirst);
}

function languageTarget(nextLang) {
  if (active === 'recipes') return langPath(nextLang, 'recipes', recipeId || (data.i18n[nextLang]?.recipes?.[0]?.id || firstRecipeId));
  if (active === 'tools') return langPath(nextLang, 'tools');
  return langPath(nextLang, 'docs');
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content="Astro" />
    <meta name="theme-color" content="#07111c" />
    <title>{title}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300..900;1,14..32,300..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body class:list={[active, { hasSidebar }]}>
    <header class="topbar">
      <a class="brandMini" href={langPath(lang, 'docs')}>
        <div class="logo">CK3</div>
        <div>
          <h1>{L.brandTitle}</h1>
          <span>{L.brandSub}</span>
        </div>
      </a>

      <nav class="topCenter" aria-label="Main navigation">
        <div class="tabs">
          <a class:list={['tab', { active: active === 'docs' }]} href={langPath(lang, 'docs')} aria-current={active === 'docs' ? 'page' : undefined}>{L.tabs.docs}</a>
          <a class:list={['tab', { active: active === 'recipes' }]} href={recipeHome(lang)} aria-current={active === 'recipes' ? 'page' : undefined}>{L.tabs.recipes}</a>
          <a class:list={['tab', { active: active === 'tools' }]} href={langPath(lang, 'tools')} aria-current={active === 'tools' ? 'page' : undefined}>{L.tabs.tools}</a>
        </div>
      </nav>

      <div class="topActions">
        <select class="langSelect" data-lang-select aria-label="Language">
          {langs.map((code) => (
            <option value={languageTarget(code)} selected={code === lang}>{code.toUpperCase()}</option>
          ))}
        </select>
        <button class="themeToggle" type="button" data-theme-toggle aria-label="Toggle theme">◐</button>
      </div>
    </header>

    <div class="shell">
      {hasSidebar && (
        <aside class="leftNav">
          <div class="navGroupTitle">Current view</div>
          <nav class="navList">
            {sidebarItems.map((item) => (
              <a class:list={['navItem', { active: item.id === currentId }]} href={`#${item.id}`}>{item.title}</a>
            ))}
          </nav>
        </aside>
      )}

      <main class="content">
        <slot />
        <p class="footer">{L.tools.footer}</p>
      </main>
    </div>

    <ChecklistDrawer items={L.checklist} />

    <nav class="mobileNav" aria-label="Main navigation">
      <a class:list={['mobileTab', { active: active === 'docs' }]} href={langPath(lang, 'docs')} aria-current={active === 'docs' ? 'page' : undefined}>{L.tabs.docs}</a>
      <a class:list={['mobileTab', { active: active === 'recipes' }]} href={recipeHome(lang)} aria-current={active === 'recipes' ? 'page' : undefined}>{L.tabs.recipes}</a>
      <a class:list={['mobileTab', { active: active === 'tools' }]} href={langPath(lang, 'tools')} aria-current={active === 'tools' ? 'page' : undefined}>{L.tabs.tools}</a>
    </nav>

    <script src={`${import.meta.env.BASE_URL}scripts/site.js`} defer></script>
  </body>
</html>
