---
import AppLayout from '../../../layouts/AppLayout.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
import data from '../../../data/appData.json';

export function getStaticPaths() {
  return Object.keys(data.i18n).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const L = data.i18n[lang] || data.i18n.en;

const sections = L.docsSections.filter((s) => s.track === 'reference');

const catOrder = ['evenements', 'logique', 'interface', 'implementation'];
const catMap = sections.reduce((acc, s) => {
  const key = s.category || 'other';
  (acc[key] = acc[key] || []).push({ id: s.id, title: s.title });
  return acc;
}, {});
const sidebarGroups = catOrder
  .filter((k) => catMap[k])
  .map((k) => ({ label: L.refCategories?.[k] || k, items: catMap[k] }));

const groupedSections = catOrder
  .filter((k) => catMap[k])
  .map((k) => ({
    key: k,
    label: L.refCategories?.[k] || k,
    sections: sections.filter((s) => s.category === k),
  }));
---

<AppLayout
  lang={lang}
  active="docs"
  title={L.metaTitle}
  sidebarGroups={sidebarGroups}
  filterPlaceholder={L.refCategories?.filterPlaceholder}
>
  <section class="hero">
    <div class="kicker">{L.heroEyebrow}</div>
    <h2>{L.heroTitle}</h2>
    <p>{L.heroText}</p>
  </section>

  {groupedSections.map((group) => (
    <div class="trackBlock" data-category={group.key}>
      <div class="trackHeader">
        <span class="trackLabel">{group.label}</span>
        <span class="trackCount">{group.sections.length}</span>
      </div>

      {group.sections.map((section) => (
        <section class="section" id={section.id}>
          <div class="sectionHead">
            <span class="kicker">{section.kicker}</span>
            <a class="anchor" href={`#${section.id}`} aria-label="Lien permanent">#</a>
          </div>
          <h2>{section.title}</h2>
          {section.html && <div class="prose" set:html={section.html} />}
          {section.diagram && <div class="diagram">{section.diagram}</div>}
          {section.code && (
            <div class="codewrap">
              <div class="codeHeader">
                <span class="codeTitle">structure</span>
                <button class="copyButton" type="button" data-copy-code>
                  <span class="copyLabel">Copy</span>
                </button>
              </div>
              <pre><code>{section.code}</code></pre>
            </div>
          )}
          {section.snippet && (
            <CodeBlock code={data.snippets[section.snippet] || ''} title={section.snippet} />
          )}
          {section.multiSnippets && (
            <div class="multiCode">
              {section.multiSnippets.map(([snipLabel, snipKey]) => (
                <CodeBlock code={data.snippets[snipKey] || ''} title={snipLabel} />
              ))}
            </div>
          )}
        </section>
      ))}
    </div>
  ))}
</AppLayout>
