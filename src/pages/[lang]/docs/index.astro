---
import AppLayout from '../../../layouts/AppLayout.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
import data from '../../../data/appData.json';

export function getStaticPaths() {
  return Object.keys(data.i18n).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const L = data.i18n[lang] || data.i18n.en;
const sidebarItems = L.docsSections.map((section) => ({ id: section.id, title: section.title }));
---

<AppLayout lang={lang} active="docs" title={L.metaTitle} sidebarItems={sidebarItems}>
  <section class="hero">
    <div class="kicker">{L.heroEyebrow}</div>
    <h2>{L.heroTitle}</h2>
    <p>{L.heroText}</p>
  </section>

  {L.docsSections.map((section) => (
    <section class="section" id={section.id}>
      <div class="kicker">{section.kicker}</div>
      <h2>{section.title}</h2>
      {section.html && <div class="prose" set:html={section.html} />}
      {section.diagram && <div class="diagram">{section.diagram}</div>}
      {section.code && (
        <div class="codewrap">
          <div class="codeHeader">
            <span class="codeTitle">structure</span>
            <button class="copyButton" type="button" data-copy-code>Copy</button>
          </div>
          <pre><code>{section.code}</code></pre>
        </div>
      )}
      {section.snippet && (
        <CodeBlock code={data.snippets[section.snippet] || ''} title={section.snippet} />
      )}
      {section.multiSnippets && (
        <div class="multiCode">
          {section.multiSnippets.map(([label, key]) => (
            <CodeBlock code={data.snippets[key] || ''} title={label} />
          ))}
        </div>
      )}
    </section>
  ))}
</AppLayout>
